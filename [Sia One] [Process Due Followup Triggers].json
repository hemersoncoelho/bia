      "parameters": {
        "jsCode": "// Extrai o array de eventos do response do claim RPC.\n// Response: { success: true, worker: '...', events: [...] }\n// Se não houver eventos, retorna array vazio (interrompe fluxo naturalmente).\nconst response = $input.first().json;\nconst triggers = Array.isArray(response.events) ? response.events\n  : Array.isArray(response) ? response\n  : [];\n\nif (triggers.length === 0) {\n  console.log('[follow_up_check_started] nenhum trigger due encontrado');\n  return [];\n}\n\nconsole.log('[follow_up_check_started] triggers_due=' + triggers.length);\nreturn triggers.map(t => ({ json: t }));\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 300],
      "id": "f3a4b5c6-d7e8-9012-fab3-456789012304",
      "name": "split_trigger_items"
    },
    {
      "parameters": {
        "jsCode": "// Dados já resolvidos pelo claim RPC: phone, instance_token, idempotency_key.\n// Valida campos obrigatórios e passa o contexto completo adiante.\nconst t = $input.item.json;\n\nconst company_id      = t.company_id      || null;\nconst contact_id      = t.contact_id      || null;\nconst conversation_id = t.conversation_id || null;\nconst trigger_id      = t.trigger_id      || null;\nconst trigger_type    = t.trigger_type    || 'no_response_after_ai_question';\nconst detected_event  = t.detected_event  || null;\nconst recipient_phone = t.recipient_phone || null;\nconst instance_id     = t.instance_id     || null;\nconst instance_token  = t.instance_token  || null;\nconst attempts        = t.attempts        || 1;\n\nconst recommended_message = (\n  t.recommended_message ||\n  'Olá! Tudo bem? Queria dar continuidade à nossa conversa. Posso ajudar com algo?'\n).trim();\n\n// idempotency_key já vem do claim RPC; fallback caso não esteja presente.\nconst idempotency_key = t.idempotency_key || [\n  'fup',\n  company_id      || 'nocompany',\n  contact_id      || 'nocontact',\n  conversation_id || 'noconv',\n  trigger_id      || 'notrigger'\n].join('_');\n\nif (!company_id || !contact_id) {\n  console.log('[follow_up_rpc_error] trigger sem company_id ou contact_id: ' + trigger_id);\n  return [];\n}\n\nreturn [{\n  json: {\n    company_id,\n    contact_id,\n    conversation_id,\n    trigger_id,\n    trigger_type,\n    detected_event,\n    recommended_message,\n    idempotency_key,\n    recipient_phone,\n    instance_id,\n    instance_token,\n    attempts\n  }\n}];\n"
      },
