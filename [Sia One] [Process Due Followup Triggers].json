    {
      "parameters": {
        "jsCode": "const reg = $input.item.json;\nconst ctx = $('build_register_payload').item.json;\n\nif (reg && reg.duplicate === true) {\n  console.log('[follow_up_duplicate_ignored] idempotency_key=' + ctx.idempotency_key +\n    ' follow_up_event_id=' + reg.follow_up_event_id);\n} else if (reg && reg.success === true) {\n  console.log('[follow_up_sent_registered]' +\n    ' company_id='        + ctx.company_id +\n    ' contact_id='        + ctx.contact_id +\n    ' conversation_id='   + ctx.conversation_id +\n    ' trigger_id='        + ctx.trigger_id +\n    ' follow_up_event_id='+ reg.follow_up_event_id +\n    ' attempt_number='    + reg.attempt_number +\n    ' cycle_id='          + reg.cycle_id +\n    ' duplicate='         + reg.duplicate);\n} else {\n  console.log('[follow_up_rpc_error] rpc_register_follow_up_sent falhou:' +\n    JSON.stringify(reg));\n}\n\nreturn [{ json: {\n  company_id:         ctx.company_id,\n  trigger_id:         ctx.trigger_id,\n  operation_id:       ctx.operation_id,\n  follow_up_event_id: reg ? reg.follow_up_event_id : null,\n  register_success:   reg ? (reg.success === true) : false,\n  duplicate:          reg ? reg.duplicate : false\n}}];\n"
      },
      "type": "n8n-nodes-base.code",
