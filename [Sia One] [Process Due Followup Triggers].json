      "parameters": {
        "jsCode": "// Falha no envio via UAZAPI. Logar e marcar trigger para retry.\n// O trigger permanece em 'due' neste caso para nova tentativa no próximo ciclo.\n// Não marcar como 'skipped' pois pode ser falha temporária de rede.\nconst ctx = $('prepare_send').item.json;\nconsole.log('[follow_up_rpc_error] falha_uazapi' +\n  ' company_id='   + ctx.company_id +\n  ' contact_id='   + ctx.contact_id +\n  ' trigger_id='   + ctx.trigger_id +\n  ' phone='        + ctx.phone);\nreturn [{ json: { logged: true, company_id: ctx.company_id, trigger_id: ctx.trigger_id } }];\n"
      },
