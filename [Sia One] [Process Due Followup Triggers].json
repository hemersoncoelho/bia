    {
      "parameters": {
        "jsCode": "// Preparação não disponível (sem telefone ou sem integração UAZAPI).\n// Trigger será retentado no próximo ciclo via rpc_mark_followup_trigger_failed.\nconst ctx = $json;\nconsole.log('[follow_up_blocked]' +\n  ' skip_reason=' + ctx.skip_reason +\n  ' company_id='  + ctx.company_id +\n  ' trigger_id='  + ctx.trigger_id);\nreturn [{ json: { logged: true } }];\n"
      },
