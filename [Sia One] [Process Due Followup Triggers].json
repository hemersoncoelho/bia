    {
      "parameters": {
        "jsCode": "// allowed=false: extrair reason e decidir se precisa de stop_cycle.\nconst block = $('can_send_check').item.json;\nconst ctx   = $('build_context').item.json;\n\nconst reason = block.reason || 'unknown';\n\nconst needs_stop_reasons = ['max_attempts_reached', 'opt_out', 'cycle_stopped'];\nconst needs_stop = needs_stop_reasons.includes(reason);\n\nconst stop_reason_map = {\n  'max_attempts_reached': 'max_attempts_reached',\n  'opt_out':              'opt_out',\n  'cycle_stopped':        'manual_cancel'\n};\nconst stop_reason = stop_reason_map[reason] || 'manual_cancel';\nconst skip_reason = 'follow_up_blocked_' + reason;\n\nconsole.log('[follow_up_blocked]' +\n  ' company_id='     + ctx.company_id +\n  ' contact_id='     + ctx.contact_id +\n  ' conversation_id='+ ctx.conversation_id +\n  ' trigger_id='     + ctx.trigger_id +\n  ' reason='         + reason +\n  ' needs_stop='     + needs_stop);\n\nreturn [{\n  json: {\n    company_id:      ctx.company_id,\n    contact_id:      ctx.contact_id,\n    conversation_id: ctx.conversation_id || null,\n    trigger_id:      ctx.trigger_id,\n    reason,\n    needs_stop,\n    stop_reason,\n    skip_reason\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1700, 500],
      "id": "f3a4b5c6-d7e8-9012-fab3-456789012340",
      "name": "parse_block"
