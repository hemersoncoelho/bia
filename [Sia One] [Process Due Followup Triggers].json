    {
      "parameters": {
        "jsCode": "// Valida telefone e integração, e monta payload para envio.\nconst ctx         = $('build_context').item.json;\nconst can_send    = $('can_send_check').item.json;\nconst phoneArr    = $('get_contact_phone').item.json;\nconst integration = $('get_company_integration').item.json;\n\n// Extrair telefone: PostgREST retorna array de objetos\nconst phone = Array.isArray(phoneArr) && phoneArr[0]\n  ? (phoneArr[0].normalized_value || null)\n  : null;\n\nif (!phone) {\n  console.log('[follow_up_rpc_error] telefone não encontrado para contato: ' + ctx.contact_id);\n  return [{ json: { ...ctx, skip: true, skip_reason: 'no_phone' } }];\n}\n\nif (!integration || !integration.success || !integration.instance_token) {\n  console.log('[follow_up_rpc_error] integração UAZAPI não encontrada para empresa: ' + ctx.company_id);\n  return [{ json: { ...ctx, skip: true, skip_reason: 'no_uazapi_integration' } }];\n}\n\nreturn [{\n  json: {\n    company_id:       ctx.company_id,\n    contact_id:       ctx.contact_id,\n    conversation_id:  ctx.conversation_id,\n    trigger_id:       ctx.trigger_id,\n    trigger_type:     ctx.trigger_type,\n    idempotency_key:  ctx.idempotency_key,\n    recommended_message: ctx.recommended_message,\n    phone,\n    instance_token:   integration.instance_token,\n    instance_id:      integration.instance_id,\n    attempt_number:   can_send.attempt_number || 1,\n    cycle_id:         can_send.cycle_id       || null,\n    skip:             false\n  }\n}];\n"
      },
