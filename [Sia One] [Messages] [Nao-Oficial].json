    {
      "parameters": {
        "jsCode": "const savedRow = $('If').first().json;\nconst payload = savedRow.raw_payload || {};\nconst msg = payload.message || {};\nconst chat = payload.chat || {};\n\n// ── NORMALIZAÇÃO DO PHONE (formato: 558898325848) ─────────────\n// Remove tudo que não for dígito, garante prefixo 55 quando ausente\nlet rawPhone = chat.phone || msg.chatid?.split('@')[0] || '';\nlet phone = rawPhone.replace(/[^0-9]/g, '');\nif (phone.startsWith('0')) phone = phone.slice(1);\n// Número BR sem DDI (10 ou 11 dígitos) → adiciona 55\nif (phone.length >= 10 && phone.length <= 11) phone = '55' + phone;\n\n// ── EXTRAÇÃO DE METADADOS DO LEAD (campos UAZAPI) ─────────────\nconst leadMetadata = {};\nfor (let i = 1; i <= 20; i++) {\n  const key = `lead_field${String(i).padStart(2, '0')}`;\n  if (chat[key]) leadMetadata[key] = chat[key];\n}\nif (chat.lead_name)         leadMetadata.lead_name = chat.lead_name;\nif (chat.lead_fullName)     leadMetadata.lead_fullName = chat.lead_fullName;\nif (chat.lead_status)       leadMetadata.lead_status = chat.lead_status;\nif (chat.lead_tags?.length) leadMetadata.lead_tags = chat.lead_tags;\nif (chat.lead_notes)        leadMetadata.lead_notes = chat.lead_notes;\nif (chat.lead_personalid)   leadMetadata.lead_personalid = chat.lead_personalid;\nif (chat.lead_email)        leadMetadata.lead_email = chat.lead_email;\nif (msg.track_source)       leadMetadata.track_source = msg.track_source;\nif (msg.track_id)           leadMetadata.track_id = msg.track_id;\nleadMetadata.instance_name  = payload.instanceName || '';\n\n// ─────────────────────────────────────────────────────────────\nconst fromMe = msg.fromMe === true;\nconst externalId = msg.messageid || savedRow.external_id || '';\nconst senderName = msg.senderName || chat.wa_name || '';\nconst instanceName = payload.instanceName || '';\n\nconst timestamp = msg.messageTimestamp\n  ? new Date(Number(msg.messageTimestamp)).toISOString()\n  : new Date().toISOString();\n\nconst uazapiType = (msg.messageType || '').toLowerCase();\nconst simpleType = msg.type || '';\nconst content = msg.content || {};\n\nlet messageType = 'text';\nlet body = msg.text || '';\nlet mediaUrl = null;\nlet mediaMimeType = null;\nlet mediaFilename = null;\nlet thumbnailUrl = null;\nlet reactionEmoji = null;\nlet quotedExternalId = null;\nlet metadata = {};\n\nswitch (uazapiType) {\n  case 'conversation':\n  case 'extendedtextmessage':\n    messageType = 'text';\n    body = msg.text || content.text || '';\n    const adReply = content.contextInfo?.externalAdReply;\n    if (adReply) {\n      metadata.ad_title = adReply.title || '';\n      metadata.ad_media_url = adReply.mediaURL || '';\n    }\n    if (content.contextInfo?.quotedMessage) {\n      quotedExternalId = content.contextInfo?.stanzaId || null;\n    }\n    break;\n\n  case 'audiomessage':\n    messageType = 'audio';\n    body = '';\n    mediaUrl = content.URL || content.url || content.directPath || null;\n    mediaMimeType = content.mimetype || 'audio/ogg; codecs=opus';\n    metadata.seconds = content.seconds || 0;\n    metadata.ptt = content.PTT || content.ptt || false;\n    break;\n\n  case 'imagemessage':\n    messageType = 'image';\n    body = msg.text || content.caption || '';\n    mediaUrl = content.URL || content.url || content.directPath || null;\n    mediaMimeType = content.mimetype || 'image/jpeg';\n    break;\n\n  case 'videomessage':\n    messageType = 'video';\n    body = msg.text || content.caption || '';\n    mediaUrl = content.URL || content.url || content.directPath || null;\n    mediaMimeType = content.mimetype || 'video/mp4';\n    metadata.seconds = content.seconds || 0;\n    break;\n\n  case 'documentmessage':\n  case 'documentwithcaptionmessage':\n    messageType = 'document';\n    body = msg.text || content.caption || content.title || '';\n    mediaUrl = content.URL || content.url || content.directPath || null;\n    mediaMimeType = content.mimetype || 'application/octet-stream';\n    mediaFilename = content.fileName || content.title || 'documento';\n    break;\n\n  case 'stickermessage':\n    messageType = 'sticker';\n    mediaUrl = content.URL || content.url || content.directPath || null;\n    mediaMimeType = content.mimetype || 'image/webp';\n    break;\n\n  case 'locationmessage':\n  case 'livelocationmessage':\n    messageType = 'location';\n    metadata.latitude = content.degreesLatitude;\n    metadata.longitude = content.degreesLongitude;\n    metadata.address = content.address || '';\n    body = content.name || `${content.degreesLatitude}, ${content.degreesLongitude}`;\n    break;\n\n  case 'contactmessage':\n  case 'contactsarraymessage':\n    messageType = 'contact_card';\n    body = content.displayName || msg.text || 'Contato';\n    break;\n\n  case 'reactionmessage':\n    messageType = 'reaction';\n    reactionEmoji = msg.reaction || content.text || '';\n    quotedExternalId = content.key?.id || null;\n    break;\n\n  default:\n    if (simpleType === 'image') messageType = 'image';\n    else if (simpleType === 'audio') messageType = 'audio';\n    else if (simpleType === 'video') messageType = 'video';\n    else if (simpleType === 'document') messageType = 'document';\n    else if (simpleType === 'sticker') messageType = 'sticker';\n    else messageType = simpleType || 'unknown';\n    body = msg.text || '';\n    break;\n}\n\nif (!quotedExternalId && msg.quoted) {\n  quotedExternalId = String(msg.quoted);\n}\n\nreturn [{\n  json: {\n    phone,\n    instance_name: instanceName,\n    sender_name: senderName,\n    direction: fromMe ? 'outbound' : 'inbound',\n    sender_type: fromMe ? 'user' : 'contact',\n    message_type: messageType,\n    body: body || '',\n    media_url: mediaUrl,\n    media_mime_type: mediaMimeType,\n    media_filename: mediaFilename,\n    thumbnail_url: thumbnailUrl,\n    external_message_id: externalId,\n    quoted_external_id: quotedExternalId,\n    reaction_emoji: reactionEmoji,\n    metadata: metadata,\n    lead_metadata: leadMetadata,\n    raw_provider_payload: payload,\n    timestamp,\n    company_id: $('busca_empresa1').first().json.company_id || null,\n    raw_event_id: savedRow.id,\n  }\n}];\n"
      },
